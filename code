<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Sine Wave Visualiser</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            background-color: #0f172a;
            color: #f8fafc;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            box-sizing: border-box;
        }
        .container {
            width: 100%;
            max-width: 800px;
            background-color: #1e293b;
            padding: 24px;
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }
        h1 {
            margin: 0 0 8px 0;
            font-size: 24px;
            text-align: center;
            color: #38bdf8;
        }
        p {
            margin: 0 0 20px 0;
            text-align: center;
            color: #94a3b8;
            font-size: 14px;
        }
        canvas {
            width: 100%;
            height: 300px;
            background-color: #020617;
            border-radius: 8px;
            border: 1px solid #334155;
            display: block;
        }
        .controls {
            margin-top: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .control-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .label-container {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            font-weight: 500;
        }
        .value-display {
            color: #38bdf8;
        }
        input[type="range"] {
            -webkit-appearance: none;
            width: 100%;
            height: 6px;
            background: #334155;
            border-radius: 5px;
            outline: none;
        }
        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #38bdf8;
            cursor: pointer;
            transition: transform 0.1s ease;
        }
        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }
        .btn-container {
            display: flex;
            justify-content: center;
            margin-top: 8px;
        }
        button {
            background-color: #0284c7;
            color: white;
            border: none;
            padding: 12px 32px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: background-color 0.2s;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        button:hover {
            background-color: #0369a1;
        }
        button.playing {
            background-color: #ef4444;
        }
        button.playing:hover {
            background-color: #dc2626;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Sine Wave Synthesizer & Visualiser</h1>
    <p>Adjust the controls below to change both the visual wave and the audio pitch in real-time.</p>
    
    <canvas id="waveCanvas"></canvas>
    
    <div class="controls">
        <div class="btn-container">
            <button id="audioBtn">Start Audio</button>
        </div>

        <div class="control-group">
            <div class="label-container">
                <span>Frequency (Pitch)</span>
                <span id="freqVal" class="value-display">440 Hz</span>
            </div>
            <input type="range" id="frequency" min="110" max="880" step="1" value="440">
        </div>

        <div class="control-group">
            <div class="label-container">
                <span>Amplitude (Volume)</span>
                <span id="ampVal" class="value-display">50%</span>
            </div>
            <input type="range" id="amplitude" min="0" max="100" step="1" value="50">
        </div>
    </div>
</div>

<script>
    // Elements
    const canvas = document.getElementById('waveCanvas');
    const ctx = canvas.getContext('2d');
    const audioBtn = document.getElementById('audioBtn');
    const freqInput = document.getElementById('frequency');
    const ampInput = document.getElementById('amplitude');
    const freqVal = document.getElementById('freqVal');
    const ampVal = document.getElementById('ampVal');

    // Resize canvas properly for high-DPI displays
    function resizeCanvas() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width * window.devicePixelRatio;
        canvas.height = rect.height * window.devicePixelRatio;
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    }
    
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    // App State
    let isPlaying = false;
    let audioCtx = null;
    let oscillator = null;
    let gainNode = null;
    let phase = 0;

    // Web Audio API Initialization
    function initAudio() {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        oscillator = audioCtx.createOscillator();
        gainNode = audioCtx.createGain();

        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(parseFloat(freqInput.value), audioCtx.currentTime);
        
        // Map slider value 0-100 to volume 0.0-0.3 safely to protect ears
        const volume = (parseFloat(ampInput.value) / 100) * 0.3;
        gainNode.gain.setValueAtTime(volume, audioCtx.currentTime);

        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);
        oscillator.start();
    }

    function toggleAudio() {
        if (!isPlaying) {
            if (!audioCtx) initAudio();
            if (audioCtx.state === 'suspended') audioCtx.resume();
            
            audioBtn.textContent = 'Stop Audio';
            audioBtn.classList.add('playing');
            isPlaying = true;
        } else {
            if (audioCtx) {
                // Smoothly fade out to prevent clicks
                gainNode.gain.setTargetAtTime(0, audioCtx.currentTime, 0.01);
                setTimeout(() => {
                    oscillator.stop();
                    audioCtx.close();
                    audioCtx = null;
                }, 50);
            }
            audioBtn.textContent = 'Start Audio';
            audioBtn.classList.remove('playing');
            isPlaying = false;
        }
    }

    // Input Listeners
    freqInput.addEventListener('input', (e) => {
        const val = e.target.value;
        freqVal.textContent = `${val} Hz`;
        if (oscillator && audioCtx) {
            oscillator.frequency.setTargetAtTime(parseFloat(val), audioCtx.currentTime, 0.01);
        }
    });

    ampInput.addEventListener('input', (e) => {
        const val = e.target.value;
        ampVal.textContent = `${val}%`;
        if (gainNode && audioCtx) {
            const volume = (parseFloat(val) / 100) * 0.3;
            gainNode.gain.setTargetAtTime(volume, audioCtx.currentTime, 0.01);
        }
    });

    audioBtn.addEventListener('click', toggleAudio);

    // Animation Loop (Canvas Drawing)
    function draw() {
        const width = canvas.width / window.devicePixelRatio;
        const height = canvas.height / window.devicePixelRatio;
        
        ctx.clearRect(0, 0, width, height);

        // Draw Center Baseline Grid
        ctx.strokeStyle = '#1e293b';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, height / 2);
        ctx.lineTo(width, height / 2);
        ctx.stroke();

        // Get live parameters
        const currentFreq = parseFloat(freqInput.value);
        const currentAmp = parseFloat(ampInput.value);

        // Convert parameters to pixels
        const displayAmplitude = (currentAmp / 100) * (height / 2.5);
        // Scale frequency down so it fits nicely on a standard screen length
        const displayCycles = (currentFreq / 200) * 0.05;

        // Draw Sine Wave
        ctx.strokeStyle = '#38bdf8';
        ctx.lineWidth = 3;
        ctx.shadowBlur = 15;
        ctx.shadowColor = '#0ea5e9';
        ctx.beginPath();

        for (let x = 0; x < width; x++) {
            // Formula: y = midPoint + Amplitude * sin(x * frequencyScaling + Phase)
            const y = height / 2 + displayAmplitude * Math.sin(x * displayCycles + phase);
            
            if (x === 0) {
                ctx.moveTo(x, y);
            } else {
                ctx.lineTo(x, y);
            }
        }

        ctx.stroke();
        ctx.shadowBlur = 0; // Reset shadow for next render

        // Increment phase to animate the movement (speed matches pitch speed context)
        const speed = (currentFreq / 440) * 0.08;
        phase -= speed;

        requestAnimationFrame(draw);
    }

    // Start animation loop
    requestAnimationFrame(draw);
</script>

</body>
</html>
